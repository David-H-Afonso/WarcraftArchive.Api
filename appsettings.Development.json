{
  "Logging": {
    "LogLevel": {
      "Default": "Debug",
      "Microsoft.AspNetCore": "Information",
      "Microsoft.EntityFrameworkCore": "Information"
    }
  },
  "DatabaseSettings": {
    "DatabasePath": "../warcraftarchive-dev.db",
    "EnableSensitiveDataLogging": true
  },
  "JwtSettings": {
    "SecretKey": "DevOnlySecretKeyThatIsAtLeast32CharactersLong!",
    "Issuer": "WarcraftArchive.Api.Dev",
    "Audience": "WarcraftArchive.Client.Dev",
    "AccessTokenMinutes": 60,
    "RefreshTokenDays": 7
  },
  "CorsSettings": {
    "AllowedOrigins": [
      "http://localhost:3000",
      "http://localhost:5173",
      "http://localhost:8080"
    ]
  },
  "SeedSettings": {
    "AdminEnabled": true,
    "AdminEmail": "admin@local",
    "AdminUsername": "admin",
    "AdminPassword": "Admin123!",
    "DemoImportEnabled": false,
    "CsvDataPath": "../data/csv"
  }
}
